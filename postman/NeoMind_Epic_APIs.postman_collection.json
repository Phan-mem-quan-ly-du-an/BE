{
  "info": {
    "name": "NeoMind Epic APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080"},
    {"key": "projectId", "value": ""},
    {"key": "token", "value": ""},
    {"key": "epicId", "value": ""},
    {"key": "taskId", "value": ""}
  ],
  "item": [
    {
      "name": "Create Epic",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/epics",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","epics"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Epic sample\",\n  \"description\": \"Description...\",\n  \"startDate\": \"2025-01-01\",\n  \"endDate\": \"2025-01-31\"\n}"
        }
      }
    },
    {
      "name": "List Epics",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/epics?page=0&size=20&sort=id,desc",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","epics"],
          "query": [
            {"key": "page", "value": "0"},
            {"key": "size", "value": "20"},
            {"key": "sort", "value": "id,desc"}
          ]
        }
      }
    },
    {
      "name": "Search Epics",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/epics/search?page=0&size=20&sort=id,desc",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","epics","search"],
          "query": [
            {"key": "page", "value": "0"},
            {"key": "size", "value": "20"},
            {"key": "sort", "value": "id,desc"}
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"q\": \"epic\",\n  \"startDateFrom\": null,\n  \"startDateTo\": null,\n  \"endDateFrom\": null,\n  \"endDateTo\": null\n}"
        }
      }
    },
    {
      "name": "Get Epic Detail",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/epics/{{epicId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","epics","{{epicId}}"]
        }
      }
    },
    {
      "name": "List Tasks In Epic",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/epics/{{epicId}}/tasks?page=0&size=20&sort=orderIndex,asc",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","epics","{{epicId}}","tasks"],
          "query": [
            {"key": "page", "value": "0"},
            {"key": "size", "value": "20"},
            {"key": "sort", "value": "orderIndex,asc"}
          ]
        }
      }
    },
    {
      "name": "Update Epic",
      "request": {
        "method": "PUT",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/epics/{{epicId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","epics","{{epicId}}"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Epic updated\",\n  \"description\": \"Updated...\",\n  \"startDate\": \"2025-01-05\",\n  \"endDate\": \"2025-02-01\"\n}"
        }
      }
    },
    {
      "name": "Delete Epic",
      "request": {
        "method": "DELETE",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/epics/{{epicId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","epics","{{epicId}}"]
        }
      }
    },
    {
      "name": "Assign Task to Epic",
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/tasks/{{taskId}}/epic?epicId={{epicId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","tasks","{{taskId}}","epic"],
          "query": [
            {"key": "epicId", "value": "{{epicId}}"}
          ]
        }
      }
    },
    {
      "name": "Unassign Task Epic",
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/tasks/{{taskId}}/epic",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","tasks","{{taskId}}","epic"]
        }
      }
    }
    ,
    {
      "name": "Create Task In Epic",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{token}}"}
        ],
        "url": {
          "raw": "{{baseUrl}}/api/projects/{{projectId}}/epics/{{epicId}}/tasks",
          "host": ["{{baseUrl}}"],
          "path": ["api","projects","{{projectId}}","epics","{{epicId}}","tasks"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"New task in epic\",\n  \"description\": \"...\",\n  \"priority\": \"MEDIUM\",\n  \"dueDate\": null,\n  \"assigneeId\": null,\n  \"sprintId\": null,\n  \"tags\": \"\",\n  \"orderIndex\": 0\n}"
        }
      }
    }
  ]
}
